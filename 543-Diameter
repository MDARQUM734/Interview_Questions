class Solution {
    int ans = 0;
    public int height(TreeNode root){
        if(root == null) return 0;
        int left = height(root.left);
        int right = height(root.right);
        ans = Math.max(ans,left+right);
        return Math.max(left,right)+1; // yaha ham kewal height function me thoda sa change kr rahe kyoki koi na koi node diamter ka part hoga aur wo ans me mil jagea
    }
    public int diameterOfBinaryTree(TreeNode root) {
        int n = height(root);
        return ans;
    }
}
